# Local: copy this file to `.env.local` and fill in real values.
# Cloud (Vercel): add the same variable NAMES in Project → Settings → Environment Variables.
# Use “All environments” (or at least Production + Preview) so preview URLs work too.

# Supabase project URL (Dashboard → Project Settings → API)
SUPABASE_URL=

# Supabase service role key (Dashboard → API → service_role — not the anon key)
SUPABASE_SERVICE_ROLE_KEY=

# Long random secret for signing session cookies (e.g. 32+ characters)
SESSION_SECRET=

# Optional — session lifetime in seconds (default in app is 12 hours if unset)
# SESSION_MAX_AGE_SECONDS=43200
